# Environment Variables - Development
# Copy this to .env and fill in with your local values
# This file is for LOCAL DEVELOPMENT ONLY - never commit real secrets

# Database
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Data Source=tensionretro.db

# Admin
ADMIN_DEFAULT_USER=Cristian
ADMIN_PASSWORD=dev-password-change-me
ADMIN_TOKEN_SECRET=dev-token-secret-change-me
ADMIN_API_KEY=dev-api-key-change-me

# CORS
AllowedOrigins=http://localhost:5173;http://localhost:3000;http://127.0.0.1:5173

# Email (Gmail SMTP)
Email__Smtp__Host=smtp.gmail.com
Email__Smtp__Port=587
Email__Smtp__Username=your-gmail@gmail.com
Email__Smtp__Password=your-gmail-app-password
Email__FromEmail=your-gmail@gmail.com
Email__RecipientEmail=your-email@gmail.com

# Application
ASPNETCORE_URLS=http://+:5198

# Frontend
VITE_API_URL=http://localhost:5000
