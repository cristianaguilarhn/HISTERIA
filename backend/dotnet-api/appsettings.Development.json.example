# Configuración de desarrollo local
# Copia este archivo a appsettings.Development.json y completa los valores

{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Email": {
    "RecipientEmail": "tu@email.com",
    "FromName": "Histeria",
    "Resend": {
      "ApiKey": "re_xxxxxxxxx",
      "ApiUrl": "https://api.resend.com/emails",
      "FromEmail": "onboarding@resend.dev"
    }
  },
  "Admin": {
    "ApiKey": "cambia-este-api-key",
    "DefaultUser": "Cristian",
    "Password": "cambia-esta-contrasena",
    "TokenSecret": "cambia-este-secreto-largo"
  },
  "AllowedHosts": "*"
}
